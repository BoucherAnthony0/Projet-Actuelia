# === Fournisseur LLM ===
# "openai_compat" = LLM gratuit pour tester | "anthropic" = Claude (après validation)
LLM_PROVIDER=openai_compat

# --- Option gratuite recommandée : Google AI Studio (Gemini 2.5 Flash) ---
# Clé gratuite, sans carte bancaire : https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash

# --- Alternative gratuite : Groq (Llama 3.3 70B, très rapide) ---
# Clé : https://console.groq.com  (sans carte bancaire)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# === Plus tard : Claude (après validation) ===
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
