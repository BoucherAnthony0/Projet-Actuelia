# Copier ce fichier en .env puis renseigner une clé LLM gratuite.
# Ne jamais committer .env (déjà ignoré par .gitignore).

# --- Fournisseur LLM commutable ---
# "openai_compat" (gratuit : Gemini ou Groq, via une API compatible OpenAI)
# ou "anthropic" (Claude, en fin de projet).
LLM_PROVIDER=openai_compat

# Clé + endpoint pour le mode openai_compat.
# Google AI Studio (recommandé, gratuit) : https://aistudio.google.com/apikey
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash

# Alternative gratuite : Groq (https://console.groq.com)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

LLM_MAX_TOKENS=4096

# --- Claude (à activer en fin de projet) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
